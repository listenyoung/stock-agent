# ==========================================
# StockAgent environment template
# Copy this file to .env and fill in real values.
# Do not commit .env.
# ==========================================

DEBUG=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

NODE_TYPE=web
NODE_ID=
NODE_HEARTBEAT_INTERVAL=10
NODE_TTL=30

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=1
WEB_RELOAD=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100
REDIS_TASK_QUEUE=agent:tasks
REDIS_RESULT_CHANNEL_PREFIX=agent:results
REDIS_NODE_REGISTRY_PREFIX=agent:nodes

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=replace-with-your-mongo-password
MONGO_DATABASE=stock_agent
MONGO_AUTH_SOURCE=admin
MONGO_MAX_POOL_SIZE=50

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_RESEARCH_REPORTS_COLLECTION=research_reports
MILVUS_MARKET_SNIPPETS_COLLECTION=market_snippets
MILVUS_EMBEDDING_DIM=1024

TUSHARE_TOKEN=your-tushare-token
TUSHARE_RATE_LIMIT=200
TUSHARE_BATCH_SIZE=100

LLM_PROVIDER=deepseek
LLM_API_KEY=your-llm-api-key
LLM_API_BASE=
LLM_MODEL_NAME=deepseek-chat
LLM_EMBEDDING_MODEL=embedding-2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_MAX_CONCURRENT_REQUESTS=10

LLM_EMBEDDING_PROVIDER=zhipu
LLM_EMBEDDING_API_KEY=your-embedding-api-key
LLM_EMBEDDING_API_BASE=

SYNC_STOCK_BASIC_SCHEDULE=0 18 * * 1-5
SYNC_STOCK_DAILY_SCHEDULE=5 18 * * 1-5
SYNC_NEWS_SCHEDULE=0 */2 * * *
SYNC_INDEX_BASIC_SCHEDULE=5 18 * * 1-5
SYNC_INDEX_DAILY_SCHEDULE=5 18 * * 1-5
SYNC_MONEYFLOW_INDUSTRY_SCHEDULE=5 18 * * 1-5
SYNC_MONEYFLOW_CONCEPT_SCHEDULE=5 18 * * 1-5
SYNC_LIMIT_LIST_SCHEDULE=5 18 * * 1-5
SYNC_DAILY_STATS_SCHEDULE=15 18 * * 1-5

OBS_LOG_LEVEL=INFO
OBS_LOG_TO_FILE=true
OBS_LOG_DIR=logs
OBS_LOG_MAX_SIZE_MB=50
OBS_LOG_BACKUP_COUNT=10
OBS_LOKI_ENABLED=false
OBS_LOKI_URL=
OBS_PHOENIX_ENABLED=false
OBS_PHOENIX_PROJECT=stock-agent

LISTENER_POLL_INTERVAL=60
LISTENER_LIMIT_FETCH_TIME=09:00
LISTENER_MORNING_SESSION=09:30-11:30
LISTENER_AFTERNOON_SESSION=13:00-15:00
LISTENER_SILENT_OUTSIDE_TRADING=true

NOTIFY_WECOM_WEBHOOK=
NOTIFY_ENABLED=false
NOTIFY_MIN_INTERVAL=10

RPC_WEB_PORT=50051
RPC_INFERENCE_PORT=50052
RPC_LISTENER_PORT=50053
RPC_DATA_SYNC_PORT=50054
RPC_MCP_PORT=50055
RPC_BACKTEST_PORT=50056
RPC_TIMEOUT=10.0
RPC_MAX_RETRIES=3
